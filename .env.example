# Copy to .env and fill in. All optional for the free MVP.
# Secondary source (free 60 calls/min). Leave unset to use yfinance only.
SURGE_FINNHUB_API_KEY=

# SEC EDGAR fair-access policy requires a descriptive User-Agent with a real
# contact. A default is set in config; override here with your own contact.
# SURGE_SEC_USER_AGENT=your-app/0.1 your-email@example.com

# Override storage location if desired
# SURGE_DB_PATH=data/surge.db

# Tune the Stage-1 eligibility filter
# SURGE_MAX_PRICE=20
# SURGE_MAX_MARKET_CAP=3000000000
# SURGE_SURGE_THRESHOLD_PCT=100

# ── Trading platform ─────────────────────────────────────────────────────────
# SURGE_TRADING_MODE=paper          # paper | live (live orders are human-gated)
# SURGE_STARTING_CAPITAL=100000
# Live broker (only when broker=alpaca; live submission still needs your approval)
# SURGE_BROKER=alpaca
# SURGE_ALPACA_API_KEY=
# SURGE_ALPACA_API_SECRET=

# ── Postgres backend (optional; `uv sync --extra pg`). Set to use PG over SQLite.
# SURGE_PG_DSN=postgresql://surge:surge@localhost:5432/surge
# SURGE_REDIS_URL=redis://localhost:6379/0

# ── LLM news augmentation (optional; `uv sync --extra llm`). No key → rule-based.
# SURGE_ANTHROPIC_API_KEY=
# SURGE_ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ── Korean market / rotation module (`uv sync --extra kr`) ───────────────────
# KEYLESS: OHLCV + listings (FinanceDataReader) AND foreign/institutional net
# flows = smart money (Naver Finance). The KRX MDC account is now only needed
# for the short-balance layer (L7, 5% weight) — optional. `surge krx-check`.
# SURGE_KRX_ID=
# SURGE_KRX_PW=
# Optional shadow-only search-trend layer (free; https://developers.naver.com):
# SURGE_NAVER_CLIENT_ID=
# SURGE_NAVER_CLIENT_SECRET=
